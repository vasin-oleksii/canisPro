{% extends 'base.html.twig' %}

{% block title %}Accueil{% endblock %}

{% block body %}
<main>
  <section class="py-5 bg-body-tertiary border-bottom">
    <div class="container">
      <div class="row align-items-center g-4">
        <div class="col-lg-6">
          <span class="badge text-bg-primary mb-3">CanisPro Education</span>
          <h1 class="display-5 fw-bold mb-3">Éducation canine moderne et bienveillante</h1>
          <p class="lead text-secondary mb-4">Découvrez nos cours, inscrivez votre chien aux séances et progressez à votre rythme avec nos éducateurs.</p>
          <div class="d-flex flex-wrap gap-2">
            <a href="{{ path('app_liste_cours') }}" class="btn btn-primary btn-lg">Voir les cours</a>
          </div>
        </div>
        <div class="col-lg-6">
                    <img src="{{ asset('images/accueil/main.jpg') }}" class="img-fluid rounded-4 shadow" alt="Photo accueil CanisPro">
        </div>
      </div>
    </div>
  </section>

  <section class="py-5">
    <div class="container">
      <div class="row g-4">
        <div class="col-md-4">
          <div class="card h-100 border-0 shadow-sm">
                        <img src="{{ asset('images/accueil/Aloa_29-768x768.jpg') }}" class="card-img-top" alt="Cours canins">
            <div class="card-body">
              <h5 class="card-title">Cours adaptés</h5>
              <p class="card-text text-secondary">Cours collectifs et individuels selon le niveau de votre chien.</p>
            </div>
            <div class="card-footer bg-white border-0">
              <a href="{{ path('app_liste_cours') }}" class="btn btn-outline-primary w-100">Explorer</a>
            </div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="card h-100 border-0 shadow-sm">
                        <img src="{{ asset('images/accueil/Viktor_4-768x768.jpg') }}" class="card-img-top" alt="Séances canines">
            <div class="card-body">
              <h5 class="card-title">À propos</h5>
              <p class="card-text text-secondary">Découvrez notre centre, notre méthode d'éducation et notre vision du bien-être canin.</p>
            </div>
            <div class="card-footer bg-white border-0">
              <a href="{{ path('app_a_propos') }}" class="btn btn-outline-primary w-100">Découvrir</a>
            </div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="card h-100 border-0 shadow-sm">
                        <img src="{{ asset('images/accueil/Louguy_18-1-768x768.jpg') }}" class="card-img-top" alt="Espace membre">
            <div class="card-body">
              <h5 class="card-title">Espace membre</h5>
              <p class="card-text text-secondary">Gérez votre profil et vos chiens depuis un espace personnel simple.</p>
            </div>
            <div class="card-footer bg-white border-0">
              {% if app.user %}
                <a href="{{ path('app_membre') }}" class="btn btn-outline-primary w-100">Mon espace</a>
              {% else %}
                <a href="{{ path('app_login') }}" class="btn btn-outline-primary w-100">Se connecter</a>
              {% endif %}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</main>
{% endblock %}
