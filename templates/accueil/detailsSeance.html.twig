{# templates/seance/seance.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Détails de la séance {{ seance.id }}{% endblock %}

{% block body %}
<main role="main" style="margin-top: 32px;">

    <section class="jumbotron text-center">
        <div class="container">
            <h1 class="jumbotron-heading">Séance {{ seance.id }}</h1>
            <p class="lead text-muted">Retrouvez les détails de cette séance</p>
        </div>
    </section>

    <div class="album py-5 bg-light">
        <div class="container">
            <div class="row">

                <div class="col-md-8 offset-md-2">
                    <div class="card mb-4 shadow-sm">
                        <div class="card-body">
                            <p><strong>Date :</strong> {{ seance.date|date('d/m/Y') }}</p>
                            <p><strong>Heure de début :</strong> {{ seance.heureDeb|date('H:i') }}</p>
                            <p><strong>Durée :</strong> {{ seance.duree|date('H:i') }}</p>
                            <p><strong>Cours :</strong> {{ seance.cour.nomCour }}</p>
                            <p><strong>Type de cour :</strong> {{ seance.cour.type.libelleType }}</p>
                            <p><strong>Niveau du cour :</strong> {{ seance.cour.niveau.libelleNiveau }}</p>
                            <p><strong>Nombre de places restantes :</strong> {{ seance.cour.type.nbPlaces - seance.inscriptions|length }}</p>

                            <h3 class="mt-4">Chiens inscrits</h3>
                            {% if seance.inscriptions|length > 0 %}
                                <ul>
                                    {% for inscription in seance.inscriptions %}
                                        {% if is_granted('ROLE_ADMIN') or (app.user and inscription.chien.proprietaire.user == app.user) %}
                                            <li>
                                                {{ inscription.chien.nomChien }} ({{ inscription.chien.race }})
                                                <a href="{{ path('app_retirer_chien', {'inscriptionId': inscription.id}) }}" class="btn btn-danger btn-sm" onclick="return confirm('Retirer?')">✕</a>
                                            </li>
                                        {% endif %}
                                    {% endfor %}
                                </ul>
                            {% else %}
                                <p>Aucun chien</p>
                            {% endif %}

                            {% set type = seance.cour.type.libelleType|lower %}
                            {% if type in ['collectif', 'collectifs'] %}
                                {% if seance.inscriptions|length >= 15 %}
                                    <button class="btn btn-success" disabled>Complet (15)</button>
                                {% else %}
                                    {% if app.user %}
                                        <a href="{{ path('app_ajouter_chien', {'seanceId': seanceId}) }}" class="btn btn-success">Ajouter chien</a>
                                    {% else %}
                                        <a href="{{ path('app_login') }}" class="btn btn-success">Ajouter chien</a>
                                    {% endif %}
                                {% endif %}
                            {% elseif type in ['individuels', 'individuel'] %}
                                {% if seance.inscriptions|length == 0 %}
                                    {% if app.user %}
                                        <a href="{{ path('app_ajouter_chien', {'seanceId': seanceId}) }}" class="btn btn-success">Ajouter chien</a>
                                    {% else %}
                                        <a href="{{ path('app_login') }}" class="btn btn-success">Ajouter chien</a>
                                    {% endif %}
                                {% else %}
                                    <button class="btn btn-success" disabled>1 chien max</button>
                                {% endif %}
                            {% endif %}

                            <a href="javascript:history.back()" class="btn btn-primary">Retour</a>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>

</main>
{% endblock %}
