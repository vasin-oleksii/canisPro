{% extends 'base.html.twig' %}

{% block title %}Séances{% endblock %}

{% block body %}
<div class="container mt-5">
    <h1 class="mb-4 text-center">Liste des Séances</h1>

    <a href="javascript:history.back()" class="btn btn-secondary mt-3">Retour</a>

    <div class="table-responsive" style="margin-top:10px;">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Date</th>
                    <th>Heure de début</th>
                    <th>Durée</th>
                    <th>Statut</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for seance in seances %}
                    {% set placesRestantes = seance.cour.type.nbPlaces - seance.inscriptions|length %}
                    <tr>
                        <td>{{ seance.date ? seance.date|date('d/m/Y') : '' }}</td>
                        <td>{{ seance.heureDeb ? seance.heureDeb|date('H:i') : '' }}</td>
                        <td>{{ seance.duree ? seance.duree|date('H:i') : '' }}</td>
                        <td>
                            {% if placesRestantes > 0 %}
                                <span class="badge bg-success">Disponible</span>
                            {% else %}
                                <span class="badge bg-danger">Complet</span>
                            {% endif %}
                        </td>
                        <td>
                            <a class="btn btn-primary btn-sm" href="{{ path('app_details_seance', {'id': seance.id}) }}">
                                Détails
                            </a>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5" class="text-center">Aucune séance</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}