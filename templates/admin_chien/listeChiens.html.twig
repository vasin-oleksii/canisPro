{% extends 'base.html.twig' %}

{% block title %}Liste des chiens{% endblock %}

{% block body %}
<div class="container mt-5">
    <h1 class="mb-4 text-center">Liste des chiens</h1>

    <a href="{{ path('app_admin_chien_ajout') }}" class="btn btn-success mb-3">Ajouter un chien</a>

    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Id</th>
                    <th>Race</th>
                    <th>Nom</th>
                    <th>Âge</th>
                    <th>Sexe</th>
                    <th>Propriétaire</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for chien in chiens %}
                    <tr>
                        <td>{{ chien.id }}</td>
                        <td>{{ chien.race }}</td>
                        <td>{{ chien.nomChien }}</td>
                        <td>{{ chien.age }}</td>
                        <td>{{ chien.sexe }}</td>
                        <td>
                            {% if chien.proprietaire %}
                                {{ chien.proprietaire.nom }} ({{ chien.proprietaire.mail }})
                            {% else %}
                                <span class="text-muted">Aucun</span>
                            {% endif %}
                        </td>
                        <td>
                            <a href="{{ path('app_admin_chien_modif', {'id': chien.id}) }}" class="btn btn-primary btn-sm">Modifier</a>
                            <form method="post" action="{{ path('app_admin_chien_delete', {'id': chien.id}) }}" onsubmit="return confirm('Vous êtes sûr de vouloir supprimer ce chien ?');" style="display:inline-block;">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ chien.id) }}">
                                <button class="btn btn-danger btn-sm">Supprimer</button>
                            </form>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="7" class="text-center">Aucun chien trouvé</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}