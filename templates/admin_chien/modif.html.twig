{% extends 'base.html.twig' %}

{% block title %}Modifier le chien{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .admin-form-hero {
            background: linear-gradient(135deg, #f5f3ff 0%, #ffffff 100%);
            border: 1px solid #ede9fe;
            border-radius: 1.2rem;
            box-shadow: 0 16px 38px rgba(109, 40, 217, .08);
        }

        .admin-form-panel,
        .admin-form-side {
            background: #fff;
            border: 1px solid #ede9fe;
            border-radius: 1rem;
            box-shadow: 0 14px 36px rgba(109, 40, 217, .07);
        }
    </style>
{% endblock %}

{% block body %}
<section class="py-4 py-lg-5">
    <div class="container">
        <div class="admin-form-hero p-4 p-lg-5 mb-4">
            <div class="row align-items-center g-4">
                <div class="col-lg-8">
                    <span class="badge text-bg-primary mb-3">Administration chiens</span>
                    <h1 class="fw-bold mb-3" style="color:#1e1b4b;">Modifier la fiche de {{ chien.nomChien }}</h1>
                    <p class="text-secondary mb-0">Mettez à jour les informations du chien pour garder une base de données propre, fiable et facile à exploiter.</p>
                </div>
                <div class="col-lg-4 text-lg-end">
                    <a href="{{ path('app_admin_chien_index') }}" class="btn btn-outline-primary">Retour à la liste</a>
                </div>
            </div>
        </div>

        <div class="row g-4 align-items-start">
            <div class="col-lg-8">
                <div class="admin-form-panel p-4 p-lg-5">
                    {{ include('admin_chien/_form.html.twig', { button_label: 'Enregistrer les modifications' }) }}
                </div>
            </div>
            <div class="col-lg-4">
                <div class="admin-form-side p-4">
                    <h2 class="h5 fw-semibold mb-3" style="color:#1e1b4b;">Rappel</h2>
                    <p class="text-secondary mb-3">Une fiche à jour permet un meilleur suivi des inscriptions, des séances et du lien avec le propriétaire.</p>
                    <div class="small text-secondary">
                        <strong style="color:#1e1b4b;">Conseil :</strong> profitez-en pour vérifier l'âge, la race et l'association au bon membre avant validation.
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}