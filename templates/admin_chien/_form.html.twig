{{ form_start(form) }}

<div class="mb-3">
    {{ form_label(form.nomChien, 'Nom du chien') }}
    {{ form_widget(form.nomChien, {'attr': {'class': 'form-control'}}) }}
</div>

<div class="mb-3">
    {{ form_label(form.race, 'Race') }}
    {{ form_widget(form.race, {'attr': {'class': 'form-control'}}) }}
</div>

<div class="mb-3">
    {{ form_label(form.age, 'Âge') }}
    {{ form_widget(form.age, {'attr': {'class': 'form-control'}}) }}
</div>

<div class="mb-3">
    {{ form_label(form.sexe, 'Sexe') }}
    {{ form_widget(form.sexe, {'attr': {'class': 'form-select'}}) }}
</div>

<div class="mb-3">
    {{ form_label(form.proprietaire, 'Propriétaire') }}
    {{ form_widget(form.proprietaire, {'attr': {'class': 'form-select'}}) }}
</div>

<button type="submit" class="btn btn-primary">
    {{ button_label|default('Enregistrer') }}
</button>

{{ form_end(form) }}