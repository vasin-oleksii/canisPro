{% extends 'base.html.twig' %}

{% block title %}Connexion{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .login-wrap {
            min-height: calc(100vh - 210px);
            display: flex;
            align-items: center;
            background: linear-gradient(135deg, #f5f3ff 0%, #ede9fe 42%, #ffffff 100%);
        }

        .login-shell {
            border: 1px solid #ddd6fe;
            border-radius: 1rem;
            overflow: hidden;
            background: #fff;
            box-shadow: 0 20px 50px rgba(109, 40, 217, .14);
        }

        .login-aside {
            background: linear-gradient(145deg, #7c3aed 0%, #6d28d9 100%);
            color: #fff;
            height: 100%;
        }

        .login-badge {
            display: inline-block;
            font-size: .72rem;
            font-weight: 600;
            letter-spacing: .05em;
            text-transform: uppercase;
            background: rgba(255,255,255,.14);
            border: 1px solid rgba(255,255,255,.2);
            border-radius: 999px;
            padding: .35rem .75rem;
        }

        .login-card-title {
            color: #1e1b4b;
            font-weight: 700;
        }

        .login-label {
            font-size: .86rem;
            font-weight: 600;
            color: #312e81;
            margin-bottom: .35rem;
        }

        .login-input {
            border: 1px solid #ddd6fe;
            border-radius: .65rem;
            min-height: 45px;
        }

        .login-input:focus {
            border-color: #8b5cf6;
            box-shadow: 0 0 0 .2rem rgba(124,58,237,.16);
        }

        .login-note {
            border: 1px solid #e9ddff;
            background: #faf7ff;
            color: #4c1d95;
            border-radius: .7rem;
            padding: .65rem .8rem;
            font-size: .84rem;
        }

        @media (max-width: 992px) {
            .login-wrap {
                min-height: auto;
                padding-top: 1.2rem;
                padding-bottom: 1.2rem;
            }
        }
    </style>
{% endblock %}

{% block body %}
    <section class="login-wrap">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-12 col-xl-10">
                    <div class="login-shell row g-0">
                        <div class="col-lg-5 d-none d-lg-block">
                            <div class="login-aside p-4 p-xl-5 d-flex flex-column justify-content-between">
                                <div>
                                    <span class="login-badge mb-3">CanisPro Education</span>
                                    <h2 class="fw-bold mb-3">Heureux de vous revoir</h2>
                                    <p class="mb-0" style="opacity:.9;">Connectez-vous pour gérer vos chiens, vos inscriptions et suivre vos séances en toute simplicité.</p>
                                </div>
                                <ul class="list-unstyled mb-0 mt-4" style="opacity:.92; font-size:.92rem;">
                                    <li class="mb-2">✓ Suivi de votre espace membre</li>
                                    <li class="mb-2">✓ Inscriptions rapides aux cours</li>
                                    <li>✓ Gestion centralisée de vos informations</li>
                                </ul>
                            </div>
                        </div>

                        <div class="col-lg-7">
                            <div class="p-4 p-md-5">
                                <h1 class="h3 login-card-title mb-2">Connexion</h1>
                                <p class="text-secondary mb-4">Accédez à votre espace personnel.</p>

                                {% if error %}
                                    <div class="alert alert-danger">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
                                {% endif %}

                                {% if app.user %}
                                    <div class="login-note mb-3">
                                        Vous êtes connecté en tant que <strong>{{ app.user.userIdentifier }}</strong>.
                                        <a href="{{ logout_path() }}" class="ms-1">Se déconnecter</a>
                                    </div>
                                {% endif %}

                                <form method="post" novalidate>
                                    <div class="mb-3">
                                        <label for="username" class="login-label">Adresse email</label>
                                        <input type="email" value="{{ last_username }}" name="_username" id="username" class="form-control login-input" autocomplete="email" required autofocus>
                                    </div>

                                    <div class="mb-3">
                                        <label for="password" class="login-label">Mot de passe</label>
                                        <input type="password" name="_password" id="password" class="form-control login-input" autocomplete="current-password" required>
                                    </div>

                                    <input type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('authenticate') }}">

                                    <button class="btn btn-primary w-100 py-2" type="submit">Se connecter</button>

                                    <div class="d-flex justify-content-between align-items-center mt-3 small">
                                        <a href="{{ path('app_accueil') }}" class="text-decoration-none">← Retour à l'accueil</a>
                                        <a href="{{ path('app_a_propos') }}" class="text-decoration-none">Découvrir CanisPro</a>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
