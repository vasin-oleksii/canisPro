{% extends 'base.html.twig' %}

{% block title %}Liste - Cours{% endblock %}

{% block body %}
<div class="container mt-5">
    <h1 class="mb-4">Liste des cours</h1>

    <div class="mb-3 text-end">
        <a href="{{ path('app_admin_cour_new') }}" class="btn btn-success">
            <i class="bi bi-plus-circle"></i> Créer un cours
        </a>
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Nom du cours</th>
                    <th>Description</th>
                    <th>Prix</th>
                    <th>Type</th>
                    <th>Niveau</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
            {% for cour in cours %}
                <tr>
                    <td>{{ cour.id }}</td>
                    <td>{{ cour.nomCour }}</td>
                    <td>{{ cour.description }}</td>
                    <td>{{ cour.prix }}</td>
                    <td>{{ cour.type.libelleType }}</td>
                    <td>{{ cour.niveau.libelleNiveau }}</td>
                    <td class="d-flex gap-1">
                        <!-- Formulaire suppression sécurisé POST -->
                        <form method="post" 
                              action="{{ path('app_admin_cour_delete', {'id': cour.id}) }}" 
                              onsubmit="return confirm('Voulez-vous vraiment supprimer ce cours ?');">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ cour.id) }}">
                            <button class="btn btn-danger btn-sm">
                                <i class="bi bi-trash"></i> Supprimer
                            </button>
                        </form>

                        <!-- Bouton Modifier -->
                        <a href="{{ path('app_admin_cour_edit', {'id': cour.id}) }}" 
                           class="btn btn-primary btn-sm">
                            <i class="bi bi-pencil"></i> Modifier
                        </a>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="5" class="text-center">Aucun cours trouvé</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}