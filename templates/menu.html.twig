{% block body %}
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container-fluid">

            <a class="navbar-brand" href="/">
                CanisPro Education
            </a>

            <ul class="navbar-nav d-flex flex-row align-items-center">
                <li class="nav-item">
                    <a class="nav-link" href="{{ path('app_liste_cours') }}" style="padding-right:0 !important;">
                        Liste des Cours
                    </a>
                </li>

                {% if is_granted('ROLE_USER') %}
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_membre') }}" style="padding-right:0 !important;">
                            Espace membre
                        </a>
                    </li>
                {% endif %}

                {% if is_granted('ROLE_ADMIN') %}
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false" style="padding-right:0 !important;">
                            Gestion
                        </a>
                        <ul class="dropdown-menu bg-dark" aria-labelledby="navbarDropdown">
                            <li><a class="dropdown-item text-white" href="{{ path('app_admin_chien_index')}}">Gestion des chiens</a></li>
                            <li><a class="dropdown-item text-white" href="#">Choix 2</a></li>
                            <li><a class="dropdown-item text-white" href="#">Choix 3</a></li>
                        </ul>
                    </li>
                {% endif %}
                
                <li class="nav-item">
                    <a class="nav-link" href="{{ path('app_a_propos') }}" style="padding-right:0 !important;">
                        À Propos
                    </a>
                </li>

                {% if app.user %}
                    <li class="nav-item d-flex align-items-center ms-3">
                        <span class="navbar-text me-2" style="text-decoration: underline;">
                            {{ app.user.userIdentifier }}
                        </span>
                        <form action="{{ path('app_logout') }}" method="post" style="display:inline;">
                            <button type="submit" class="btn btn-light">
                                Déconnexion
                            </button>
                        </form>
                    </li>
                {% else %}
                    <li class="nav-item d-flex align-items-center ms-3">
                        <a class="nav-link" href="{{ path('app_login') }}">
                            Connexion
                        </a>
                    </li>
                {% endif %}
            </ul>
        </div>
    </nav>
{% endblock %}