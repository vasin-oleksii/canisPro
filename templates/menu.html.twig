{% block body %}
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top">
        <div class="container-fluid">

            <a class="navbar-brand" href="/">
                CanisPro Education
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Basculer la navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav ms-auto d-flex flex-row flex-lg-row flex-wrap align-items-center gap-2">
                <li class="nav-item">
                    <a class="nav-link" href="{{ path('app_liste_cours') }}">
                        Liste des Cours
                    </a>
                </li>

                {% if is_granted('ROLE_USERS') %}
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_membre') }}">
                            Espace membre
                        </a>
                    </li>
                {% endif %}

                {% if is_granted('ROLE_ADMIN') %}
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            Gestion
                        </a>
                        <ul class="dropdown-menu bg-dark" aria-labelledby="navbarDropdown">
                            <li><a class="dropdown-item text-white" href="{{ path('app_admin_chien_index')}}">Gestion des chiens</a></li>
                            <li><a class="dropdown-item text-white" href="{{path('app_admin_proprietaire_index')}}">Gestion des membres</a></li>
                            <li><a class="dropdown-item text-white" href="{{ path('app_admin_inscription_index')}}">Gestion des inscriptions</a></li>
                            <li><a class="dropdown-item text-white" href="{{path('app_admin_cour_index')}}">Gestion des cours</a></li>
                            <li><a class="dropdown-item text-white" href="{{ path('app_admin_seance_index') }}">Gestion des séances</a></li>
                        </ul>
                    </li>
                {% endif %}
                
                <li class="nav-item">
                    <a class="nav-link" href="{{ path('app_a_propos') }}">
                        À Propos
                    </a>
                </li>

                {% if app.user %}
                    <li class="nav-item d-flex align-items-center">
                        <span class="navbar-text me-2" style="text-decoration: underline; font-size: 0.9rem;">
                            {{ app.user.userIdentifier }}
                        </span>
                        <form action="{{ path('app_logout') }}" method="post" class="d-inline">
                            <button type="submit" class="btn btn-light btn-sm">
                                Déconnexion
                            </button>
                        </form>
                    </li>
                {% else %}
                    <li class="nav-item d-flex align-items-center">
                        <a class="nav-link" href="{{ path('app_login') }}">
                            Connexion
                        </a>
                    </li>
                {% endif %}
            </ul>
            </div>
        </div>
    </nav>
{% endblock %}