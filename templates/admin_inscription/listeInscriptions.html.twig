{% extends 'base.html.twig' %}

{% block title %}Liste des inscriptions{% endblock %}

{% block body %}
<div class="container mt-5">
    <h1 class="mb-4 text-center">Liste des inscriptions</h1>

    <a href="{{ path('app_admin_inscription_ajout') }}" class="btn btn-success mb-3">Nouvelle inscription</a>

    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Id</th>
                    <th>Date d'inscription</th>
                    <th>Chien</th>
                    <th>Séance</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for inscription in inscriptions %}
                    <tr>
                        <td>{{ inscription.id }}</td>
                        <td>{{ inscription.dateInscription ? inscription.dateInscription|date('d/m/Y') : '' }}</td>
                        <td>
                            {% if inscription.chien %}
                                {{ inscription.chien.nomChien }} ({{ inscription.chien.race }})
                            {% else %}
                                <span class="text-muted">Aucun</span>
                            {% endif %}
                        </td>
                        <td>
                            {% if inscription.seance %}
                                {{ inscription.seance.date ? inscription.seance.date|date('d/m/Y') : '' }} à {{ inscription.seance.heureDeb ? inscription.seance.heureDeb|date('H:i') : '' }}
                            {% else %}
                                <span class="text-muted">Aucune</span>
                            {% endif %}
                        </td>
                        <td>
                            <a href="{{ path('app_admin_inscription_modif', {'id': inscription.id}) }}" class="btn btn-primary btn-sm">Modifier</a>
                            <form method="post" action="{{ path('app_admin_inscription_delete', {'id': inscription.id}) }}" style="display:inline-block;" onsubmit="return confirm('Vous êtes sûr de vouloir supprimer cette inscription ?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ inscription.id) }}">
                                <button class="btn btn-danger btn-sm">Supprimer</button>
                            </form>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5" class="text-center">Aucune inscription trouvée</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}