{% extends 'base.html.twig' %}

{% block title %}Gestion - Proprietaire{% endblock %}

{% block body %}
    <h1>Gestion des proprietaires </h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Nom</th>
                <th>Prenom</th>
                <th>Mail</th>
                <th>Tel</th>
                <th>Adresse</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for proprietaire in proprietaires %}
            <tr>
                <td>{{ proprietaire.id }}</td>
                <td>{{ proprietaire.nom }}</td>
                <td>{{ proprietaire.prenom }}</td>
                <td>{{ proprietaire.mail }}</td>
                <td>{{ proprietaire.tel }}</td>
                <td>{{ proprietaire.adresse }}</td>
                <td>
                    <a href="{{ path('app_admin_proprietaire_show', {'id': proprietaire.id}) }}">Voir</a>
                    <a href="{{ path('app_admin_proprietaire_edit', {'id': proprietaire.id}) }}">Modifier</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="7">Aucun proprietaire trouver</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_admin_proprietaire_new') }}">Crée un proprietaire</a>
{% endblock %}
