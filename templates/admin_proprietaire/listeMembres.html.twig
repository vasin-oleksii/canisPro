{% extends 'base.html.twig' %}

{% block title %}Gestion - Propriétaire{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .admin-owner-hero {
            background: linear-gradient(135deg, #f5f3ff 0%, #ede9fe 52%, #ffffff 100%);
            border: 1px solid #ede9fe;
            border-radius: 1.2rem;
            box-shadow: 0 18px 42px rgba(109, 40, 217, .08);
        }

        .admin-owner-chip {
            display: inline-flex;
            align-items: center;
            padding: .4rem .85rem;
            border-radius: 999px;
            background: rgba(124, 58, 237, .10);
            border: 1px solid rgba(124, 58, 237, .16);
            color: #7c3aed;
            font-size: .82rem;
            font-weight: 600;
        }

        .admin-owner-stat {
            height: 100%;
            background: #fff;
            border: 1px solid #ede9fe;
            border-radius: 1rem;
            padding: 1.1rem;
            box-shadow: 0 12px 28px rgba(109, 40, 217, .06);
        }

        .admin-owner-stat-number {
            font-size: 1.9rem;
            font-weight: 700;
            color: #7c3aed;
            line-height: 1;
        }

        .admin-owner-table-wrap {
            background: #fff;
            border: 1px solid #ede9fe;
            border-radius: 1rem;
            box-shadow: 0 14px 36px rgba(109, 40, 217, .08);
            overflow: hidden;
        }

        .admin-owner-table thead th {
            background: #f5f3ff;
            color: #1e1b4b;
            border-bottom: 1px solid #e9ddff;
            font-weight: 600;
            white-space: nowrap;
        }

        .admin-owner-table tbody td {
            vertical-align: middle;
            border-color: #f1eafe;
        }

        .admin-owner-address {
            max-width: 280px;
            color: #6b7280;
        }

        .admin-owner-empty {
            padding: 2.5rem 1rem;
            text-align: center;
            color: #6b7280;
        }
    </style>
{% endblock %}

{% block body %}
<section class="py-4 py-lg-5">
    <div class="container">
        <div class="admin-owner-hero p-4 p-lg-5 mb-4">
            <div class="row align-items-center g-4">
                <div class="col-lg-8">
                    <span class="admin-owner-chip mb-3">Administration membres</span>
                    <h1 class="fw-bold mb-3" style="color:#1e1b4b; font-size: clamp(2rem, 4vw, 3rem);">Gérer les propriétaires</h1>
                    <p class="text-secondary mb-0" style="max-width: 720px;">
                        Centralisez les informations des membres, mettez à jour leurs coordonnées et gardez une base de données claire pour le suivi des chiens et des inscriptions.
                    </p>
                </div>
                <div class="col-lg-4 text-lg-end">
                    <a href="{{ path('app_admin_proprietaire_new') }}" class="btn btn-primary btn-lg px-4">Créer un propriétaire</a>
                </div>
            </div>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-md-4">
                <div class="admin-owner-stat">
                    <div class="admin-owner-stat-number">{{ proprietaires|length }}</div>
                    <div class="text-secondary mt-2">Propriétaires enregistrés</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="admin-owner-stat">
                    <div class="admin-owner-stat-number">Coordonnées</div>
                    <div class="text-secondary mt-2">Accès rapide aux emails, téléphones et adresses</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="admin-owner-stat">
                    <div class="admin-owner-stat-number">Gestion</div>
                    <div class="text-secondary mt-2">Création, édition et suppression simplifiées</div>
                </div>
            </div>
        </div>

        <div class="admin-owner-table-wrap">
            <div class="table-responsive">
                <table class="table admin-owner-table align-middle mb-0">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Nom complet</th>
                            <th>Mail</th>
                            <th>Téléphone</th>
                            <th>Adresse</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for proprietaire in proprietaires %}
                        <tr>
                            <td><span class="badge text-bg-primary">#{{ proprietaire.id }}</span></td>
                            <td>
                                <div class="fw-semibold" style="color:#1e1b4b;">{{ proprietaire.prenom }} {{ proprietaire.nom }}</div>
                            </td>
                            <td>
                                <div class="fw-semibold" style="color:#1e1b4b;">{{ proprietaire.mail }}</div>
                            </td>
                            <td>{{ proprietaire.tel }}</td>
                            <td>
                                <div class="admin-owner-address">{{ proprietaire.adresse }}</div>
                            </td>
                            <td class="text-end">
                                <div class="d-flex flex-wrap justify-content-end gap-2">
                                    <a href="{{ path('app_admin_proprietaire_edit', {'id': proprietaire.id}) }}" class="btn btn-outline-primary btn-sm">Modifier</a>
                                    <form method="post" action="{{ path('app_admin_proprietaire_delete', {'id': proprietaire.id}) }}" onsubmit="return confirm('Voulez-vous vraiment supprimer ce propriétaire ?');" class="d-inline-block">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ proprietaire.id) }}">
                                        <button class="btn btn-danger btn-sm">Supprimer</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="6">
                                <div class="admin-owner-empty">
                                    <div class="fw-semibold mb-2" style="color:#1e1b4b;">Aucun propriétaire trouvé</div>
                                    <div class="mb-3">Ajoutez votre premier membre pour commencer à structurer votre base de données.</div>
                                    <a href="{{ path('app_admin_proprietaire_new') }}" class="btn btn-primary">Créer un propriétaire</a>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>
{% endblock %}