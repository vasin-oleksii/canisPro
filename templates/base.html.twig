<!DOCTYPE html>
<html>
    <head>
        <meta http-equiv="content-type" content="text/html; charset=UTF-8">
        <meta charset="utf-8">
        <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
        <link rel="icon" type="image/png" href="{{asset('images/logo-centre-icon.png')}}">
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
        <title>CanisPro Education</title>
        {% block stylesheets %}
            <style>
                :root {
                    --cp-purple: #6f42c1;
                    --cp-purple-dark: #5b33a8;
                    --cp-purple-soft: #f3edff;
                }

                body {
                    background-color: var(--cp-purple-soft);
                }

                .btn-primary {
                    background-color: var(--cp-purple) !important;
                    border-color: var(--cp-purple) !important;
                }

                .btn-primary:hover,
                .btn-primary:focus {
                    background-color: var(--cp-purple-dark) !important;
                    border-color: var(--cp-purple-dark) !important;
                }

                .btn-outline-primary {
                    color: var(--cp-purple) !important;
                    border-color: var(--cp-purple) !important;
                }

                .btn-outline-primary:hover,
                .btn-outline-primary:focus {
                    color: #fff !important;
                    background-color: var(--cp-purple) !important;
                    border-color: var(--cp-purple) !important;
                }

                .text-bg-primary,
                .badge.text-bg-primary {
                    background-color: var(--cp-purple) !important;
                }

                a {
                    transition: color .2s ease;
                }

                main a:hover {
                    color: #d7c7ff !important;
                }

                .card {
                    border-color: #e2d6ff;
                }

                .dropdown-item:hover {
                    background-color: #6c757d !important;
                    color: #ffffff !important;  /* Texte en blanc */
                }

                @media (max-width: 768px) {
                    body {
                        font-size: 14px;
                    }

                    h1, .display-5 {
                        font-size: 1.75rem !important;
                    }

                    h2 {
                        font-size: 1.5rem !important;
                    }

                    h3 {
                        font-size: 1.25rem !important;
                    }

                    .btn-lg {
                        padding: 0.5rem 1rem;
                        font-size: 0.9rem;
                    }

                    .container {
                        padding-left: 12px;
                        padding-right: 12px;
                    }
                }

                @media (max-width: 576px) {
                    h1, .display-5 {
                        font-size: 1.5rem !important;
                    }

                    h2 {
                        font-size: 1.25rem !important;
                    }

                    .lead {
                        font-size: 0.95rem;
                    }

                    .btn {
                        font-size: 0.875rem;
                        padding: 0.375rem 0.75rem;
                    }

                    .card {
                        margin-bottom: 1rem;
                    }

                    .table {
                        font-size: 0.75rem;
                    }
                }
            </style>
        {% endblock %}
    </head>
    <body class="d-flex flex-column min-vh-100">
        {% include 'menu.html.twig' %}
        <div class="flex-grow-1">
            {% block body %}{% endblock %}
        </div>

        <footer class="bg-dark text-light mt-auto border-top border-secondary-subtle">
            <div class="container py-4">
                <div class="row gy-3">
                    <div class="col-md-5">
                        <h5 class="mb-2">CanisPro Education</h5>
                        <p class="text-secondary mb-0">Club canin - cours, séances et suivi personnalisé pour votre chien.</p>
                    </div>
                    <div class="col-6 col-md-3">
                        <h6 class="text-uppercase text-secondary">Navigation</h6>
                        <ul class="list-unstyled mb-0">
                            <li><a class="link-light text-decoration-none" href="{{ path('app_accueil') }}">Accueil</a></li>
                            <li><a class="link-light text-decoration-none" href="{{ path('app_liste_cours') }}">Cours</a></li>
                            <li><a class="link-light text-decoration-none" href="{{ path('app_a_propos') }}">À propos</a></li>
                        </ul>
                    </div>
                    <div class="col-6 col-md-4">
                        <h6 class="text-uppercase text-secondary">Compte</h6>
                        <ul class="list-unstyled mb-0">
                            {% if app.user %}
                                <li><a class="link-light text-decoration-none" href="{{ path('app_membre') }}">Espace membre</a></li>
                                <li><a class="link-light text-decoration-none" href="{{ path('app_logout') }}">Déconnexion</a></li>
                            {% else %}
                                <li><a class="link-light text-decoration-none" href="{{ path('app_login') }}">Connexion</a></li>
                            {% endif %}
                        </ul>
                    </div>
                </div>
                <hr class="border-secondary my-3">
                <p class="small text-secondary mb-0">© {{ "now"|date("Y") }} CanisPro Education</p>
            </div>
        </footer>
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    </body>
</html>
